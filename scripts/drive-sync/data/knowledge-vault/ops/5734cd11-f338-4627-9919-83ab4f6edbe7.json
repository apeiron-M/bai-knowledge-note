  {
    "index": 3,
    "hash": "5eK8wLlFAjBc95uAC2VQ9zXYBSo=",
    "timestampUtcMs": "2026-05-13T13:00:33.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Permission resolution order: (1) Auth/admin check; (2) Direct user permission on document; (3) Group permission; (4) Parent inheritance recursively. Six tables: `DocumentPermission` (user-document), `Group`, `UserGroup` (memberships), `DocumentGroupPermission` (group-document), `OperationUserPermission` (user-operation), `OperationGroupPermission` (group-operation). Operation-level permissions restrict specific actions (e.g., only certain users can execute DELETE_NODE). Tables are auto-created by migrations when `DOCUMENT_PERMISSIONS_ENABLED=true`. GraphQL queries like `documentAccess`, `userDocumentPermissions`, `canExecuteOperation` expose the permission state.",
        "updatedAt": "2026-05-13T13:00:33.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:33.000Z"
    }
  },
