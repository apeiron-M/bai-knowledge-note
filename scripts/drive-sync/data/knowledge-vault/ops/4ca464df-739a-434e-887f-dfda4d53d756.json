    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "GraphQL and Schema",
        "createdAt": "2026-04-02T13:00:00.000Z",
        "description": "GraphQL as the universal schema language for Powerhouse: custom scalars, Zod validation, the design system component library, and drive operation hooks.",
        "orientation": "GraphQL is not just a query language in Powerhouse \u2014 it is the lingua franca that connects every layer of the platform. Document model schemas are defined in GraphQL SDL. Custom scalars extend the type system with domain-specific types like Currency, EthereumAddress, and OID, each backed by Zod validation to ensure runtime type safety matches compile-time guarantees. The Powerhouse design system translates these GraphQL scalars into a reusable component library, so that every scalar type has a corresponding UI input component that handles formatting, validation, and accessibility. Even drive-level operations flow through a GraphQL-typed system via the node actions hook. And in the CQRS read side, GraphQL serves as the query interface for subgraphs and processors. This MOC connects the schema primitives to their downstream consumers across the entire stack."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
