    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Achra is the coordination and front-office layer of the Powerhouse ecosystem, designed for end-user facing workflows. Its primary color is #7A3AFF (purple), which remains constant across both light and dark themes. Achra enables teams to scope work, choose providers, pay in stablecoins, and track results. The Achra design system package includes a full set of color tokens in `colors.css`, a style guide, 16 website page templates, logo assets, document templates, presentation slides, and animation references. The brand uses Poppins 600 for headings and Inter 400 for body text, consistent with the broader Powerhouse typography system. Source: https://github.com/powerhouse-inc/design-systems/tree/main/achra.",
        "updatedAt": "2026-05-13T13:00:26.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:26.000Z"
    }
