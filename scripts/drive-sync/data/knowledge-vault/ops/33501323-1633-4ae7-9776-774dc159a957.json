  {
    "index": 3,
    "hash": "7Dv8h25laiQVu7JVDq1mbJlf2Lg=",
    "timestampUtcMs": "2026-05-13T13:00:40.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Powerhouse CLI (`ph-cmd`) is the primary tool for managing Powerhouse projects. Key commands:\n\n- `ph init` - Initialize a new project (scaffolds directory structure from boilerplate)\n- `ph vetra --watch` - Launch Vetra Studio with live code generation (recommended)\n- `ph vetra --interactive` - Launch with confirmation prompts before generation\n- `ph connect` - Run Connect application locally (legacy)\n- `ph generate <file.phd>` - Manually generate code from exported specification\n- `ph generate --editor <name> --document-types <type>` - Generate editor template\n- `ph generate --drive-editor <name>` - Generate custom drive interface\n- `ph reactor` / `ph switchboard` - Start the API service\n- `ph install <package>` - Install a published Powerhouse package\n- `ph use <env>` - Switch dependency environments (latest/dev/prod/local)\n- `ph update` - Update dependencies to latest versions\n\nThe CLI supports three release channels: latest (stable), dev, and staging.",
        "updatedAt": "2026-05-13T13:00:40.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:40.000Z"
    }
  },
