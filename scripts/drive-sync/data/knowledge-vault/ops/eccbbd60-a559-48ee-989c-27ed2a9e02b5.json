    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Swarm Data Model",
        "createdAt": "2026-04-21T19:32:02.603Z",
        "description": "How Connect encodes its state on Swarm: feeds, manifests, SOCs, content-addressed chunks, and the topic namespace that ties them together.",
        "orientation": "This MOC groups the primitives and shapes that form Connect's on-Swarm data model. At the lowest layer Swarm exposes two primitives \u2014 immutable /bytes and mutable owner-signed feeds built on Single Owner Chunks. Above that Connect layers a three-tier manifest hierarchy (user \u2192 drive \u2192 document), a versioned ph:v2 topic namespace, and specialized feeds (public profile, collab index, chat history). Notes here also cover operational realities \u2014 per-topic write locks, feed-backing stamp choices, the death of epoch feeds on bee-js 11, and why manifests are uploaded encrypted to /bytes with only their hashes inlined into feeds."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
