  {
    "index": 3,
    "hash": "ZC2bpkBYEakfZ7BkBgIISE+Cc2w=",
    "timestampUtcMs": "2026-05-13T13:00:47.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "All Powerhouse brands share a consistent typography system using two Google Fonts families. Headings use Poppins at weight 600 (semibold): H1 hero text at approximately 48-64px, and H2 section headings at approximately 36px. Body text and paragraphs use Inter at weight 400 (regular) at 18-20px. Navigation links also use Inter 400 at 14-16px. The legacy powerhouse.inc site previously used Franie for headings, but the current powerhouse.io site has standardized on Poppins. Inter is consistent across all historical and current properties. Both fonts are freely available via Google Fonts. This typography system is documented in the brand analysis at https://github.com/powerhouse-inc/design-systems/blob/main/context/brand-analysis.md and implemented in the styleguide.html files for each brand.",
        "updatedAt": "2026-05-13T13:00:47.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:47.000Z"
    }
  },
