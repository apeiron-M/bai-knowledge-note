  {
    "index": 3,
    "hash": "01GPA7WO9sBJJLrkTYfD6Opback=",
    "timestampUtcMs": "2026-05-13T13:00:48.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "A `VetraPackage` is the distributable unit in Powerhouse with `id`, `name`, `description`, `category`, `author`, and a `modules` object containing optional arrays of: `documentModelModules` (VetraDocumentModelModule[]), `editorModules` (VetraEditorModule[]), `subgraphModules` (SubgraphModule[]), `importScriptModules` (ImportScriptModule[]), and `processorModules` (VetraProcessorModule[]). Packages are loaded by Connect instances via the `useVetraPackages()` hook and set via `setVetraPackages()`. The Builder Platform enables developers to publish these packages to a shared registry where they can be discovered, forked, extended, or monetized -- original authors receive a share of value generated when modules are used in other deployments.",
        "updatedAt": "2026-05-13T13:00:48.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:48.000Z"
    }
  },
