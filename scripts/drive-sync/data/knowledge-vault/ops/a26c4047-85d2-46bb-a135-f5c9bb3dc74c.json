  {
    "index": 3,
    "hash": "aCEhaTfwCKoxXWw3HzPXKDvWPWY=",
    "timestampUtcMs": "2026-05-13T13:00:41.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Powerhouse ecosystem consists of multiple products organized hierarchically. Reactor is the universal core component -- storage-agnostic, loads document models, syncs via drives. Connect is the document management web app where users create drives and install Reactor Package modules. Switchboard is the API service with GraphQL and MCP endpoints. Fusion is a Next.js boilerplate working with Switchboard as backend for SaaS-like experiences. Achra is the coordination hub (front-office, end-user facing) for scoping work, choosing providers, paying in stablecoins, and tracking results. Vetra is the infrastructure and developer platform encompassing Vetra Studio, Vetra Academy, and Vetra Switchboard, started via `ph vetra --watch`. Renown is the reputation layer tracking verified contribution and trust. Agent Rupert handles AI task automation, and the Operational Hub provides turnkey back office for global teams. Reference: https://github.com/powerhouse-inc/design-systems/blob/main/context/brand-analysis.md.",
        "updatedAt": "2026-05-13T13:00:41.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:41.000Z"
    }
  },
