  {
    "index": 3,
    "hash": "+xGQW+JGAaK6jsjB08ofxzBae8U=",
    "timestampUtcMs": "2026-05-13T13:00:43.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Renown login flow: (1) User signs a message with their Ethereum wallet; (2) A DID (`did:example:123456789abcdefghijk`) is created from the ETH key; (3) A credential is generated and stored on a Powerhouse-hosted identity node; (4) Connect uses the DID to sign operations; (5) Switchboard verifies the DID's credential and signature. Renown addresses trust in DAOs where contributors are pseudonymous -- it lets them build reputation and share cryptographic resumes across organizations without revealing real-world identity. Powerhouse plans to decentralize the identity reactor over time.",
        "updatedAt": "2026-05-13T13:00:43.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:43.000Z"
    }
  },
