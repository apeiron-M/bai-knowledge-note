  {
    "index": 3,
    "hash": "xt8gzwgovH4NHQKUEujgKYRTGEs=",
    "timestampUtcMs": "2026-05-13T13:00:33.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Since a drive is itself a document (of type `powerhouse/document-drive`) containing a list of other documents, a Drive-app is simply a custom editor for the drive document. Drive-apps receive `nodes`, `driveId`, and a `DriveEditorContext` providing methods like `getDocumentRevision`, `getDocumentModelModule`, and `getEditor`. They can use `useDriveDocumentStates({ driveId })` to fetch the state of all documents in the drive, enabling aggregated views (tables, progress bars, Kanban boards). Drive-apps are registered in `powerhouse.manifest.json` under the `apps` array and generated via Vetra Studio or `ph generate --drive-editor`.",
        "updatedAt": "2026-05-13T13:00:33.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:33.000Z"
    }
  },
