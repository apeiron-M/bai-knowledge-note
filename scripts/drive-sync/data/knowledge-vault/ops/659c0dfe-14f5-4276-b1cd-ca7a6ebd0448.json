    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Document Model System",
        "createdAt": "2026-04-02T13:00:00.000Z",
        "description": "The foundational architecture of Powerhouse document models: event sourcing, state scopes, GraphQL schemas, reducers, code generation, and versioning.",
        "orientation": "The document model system is the conceptual and technical bedrock of everything built in Powerhouse. Every piece of domain logic, every editor, every processor ultimately traces back to a document model definition. Understanding this system means understanding how GraphQL SDL schemas get transformed into typed state containers, how reducers enforce pure deterministic state transitions through Immer, and how the code generation pipeline in the gen/ folder bridges the gap between human-authored specifications and machine-executable code. This MOC collects the core primitives \u2014 from event sourcing fundamentals to OID identifiers to versioning semantics \u2014 that a developer must internalize before they can effectively build on the platform."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
