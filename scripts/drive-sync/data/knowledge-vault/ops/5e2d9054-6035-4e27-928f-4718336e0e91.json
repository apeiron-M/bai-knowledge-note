    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "All three Powerhouse brands share identical status and extra color tokens in both light and dark themes. Status colors: --progress: #329DFF (blue, with --progress-30: rgba(50, 157, 255, 0.3)), --success: #4FC86F (green, with --success-30: rgba(79, 200, 111, 0.3)), --todo: #FFA132 (orange, with --todo-30: rgba(255, 161, 50, 0.3)), --destructive: #EA4335 (red, with --destructive-foreground: #FCFCFC and --destructive-30: rgba(234, 67, 53, 0.3)). Extra colors: --yellow: #FAC400 (with --yellow-30: rgba(250, 196, 0, 0.3)), --purple: #8E55EA (with --purple-30: rgba(142, 85, 234, 0.3)). These values do not change between light and dark themes. Source: achra/colors.css, vetra/colors.css, and powerhouse/colors.css at https://github.com/powerhouse-inc/design-systems.",
        "updatedAt": "2026-05-13T13:00:44.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:44.000Z"
