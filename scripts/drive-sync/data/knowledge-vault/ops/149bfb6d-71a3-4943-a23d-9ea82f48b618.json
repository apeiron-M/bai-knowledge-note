    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Open-Source Capitalism",
        "createdAt": "2026-03-30T19:20:00.000Z",
        "description": "Economic philosophy combining pro-market OSS with sustainable incentive structures: marketplace platforms, POWTs, RGH, and investable OSS via OCF.",
        "orientation": "Open-Source Capitalism is Powerhouse's economic philosophy \u2014 the argument that open-source can be self-sustaining, investable, and scalable if paired with the right incentive structures. It rests on four principles: marketplace platforms for transparent coordination, Proof of Work Tokens for long-term contributor alignment, a Revenue Generating Hub for commercial monetization, and an Operational Collateral Fund that channels external investment into open infrastructure. This framework emerged from the failure of DAOs to deliver on decentralized coordination, and it motivates every architectural and organizational decision Powerhouse makes. Understanding OSC is prerequisite to understanding why SNOs, document models, and the two platforms exist."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
