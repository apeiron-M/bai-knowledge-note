    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Powerhouse provides pre-built components through `@powerhousedao/document-engineering/scalars`, many based on GraphQL scalar types for consistency with document model schemas. Components include Checkbox, StringField, Form, and more. They're explored via Storybook at https://storybook.powerhouse.academy where you can visually inspect components, interact with variants, view code snippets, and consult props tables. Import example: `import { Checkbox, StringField, Form } from \"@powerhousedao/document-engineering/scalars\";`",
        "updatedAt": "2026-05-13T13:00:30.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:30.000Z"
    }
