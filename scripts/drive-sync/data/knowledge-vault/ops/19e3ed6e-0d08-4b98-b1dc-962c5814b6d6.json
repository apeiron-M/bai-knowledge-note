  {
    "index": 3,
    "hash": "phvbng2+dqkZKnMQ92u7SMPnlFU=",
    "timestampUtcMs": "2026-05-13T13:00:39.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Operational Hub is a ready-to-use operational setup that gives open-source and public-goods builder teams the legal and financial infrastructure to receive funding, pay contributors, and operate compliantly from day one.\n\nStructured as a Swiss Association, it reduces personal liability for contributors, simplifies compliance, and provides a professional foundation. Target audiences include builder teams, open-source projects, and DAOs that receive grants or donations, pay contributors, or hold a treasury.\n\nThe product is ACTIVE and operated through Powerhouse's service infrastructure. It includes both one-time setup services (entity formation, registered address in Zug, VAT docs, contract templates) and recurring operational services (accounting, invoicing, payouts, contributor onboarding, expense management).\n\nThis is the first concrete revenue-generating product in the Powerhouse ecosystem \u2014 a subscription business with clear pricing tiers.",
        "updatedAt": "2026-05-13T13:00:39.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:39.000Z"
    }
  },
