    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The IP-Holding Entity (IPSPV) safeguards the SNO's intellectual property assets including trademarks, copyrights, and other IP rights. It employs a dual licensing model: copyleft licenses support open-source availability while enterprise licenses generate revenue from proprietary versions. By separating IP management from operational activities, the IPSPV ensures the SNO remains focused on innovation without losing control of its most valuable assets.",
        "updatedAt": "2026-05-13T13:00:36.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:36.000Z"
    }
  },
