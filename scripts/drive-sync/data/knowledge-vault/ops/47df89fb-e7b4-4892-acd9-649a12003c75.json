  {
    "index": 3,
    "hash": "MTJp317sBpKGLPyITtiJKCUxkoc=",
    "timestampUtcMs": "2026-05-13T13:00:36.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Inspector Modal is a Connect development tool with two tabs: Database (explore local PGlite tables with schema tree, pagination, sorting, and export/import) and Remotes (view sync remotes and their channel states). Each remote has Inbox (received operations), Outbox (pending send), and Dead Letter (failed sync with error info). Operations have statuses: Pending, Applied, or Error. Enable via URL parameter `?FEATURE_INSPECTOR_ENABLED=true` or environment variable `PH_CONNECT_INSPECTOR_ENABLED=true`. The Inspector button appears in the Connect sidebar footer.",
        "updatedAt": "2026-05-13T13:00:36.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:36.000Z"
    }
  },
