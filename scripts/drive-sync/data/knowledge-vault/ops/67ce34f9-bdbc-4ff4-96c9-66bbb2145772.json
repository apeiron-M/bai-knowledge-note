    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "A document model is a structured representation of data and workflows that captures relationships, states, and operations within a system. By treating documents as dynamic entities that evolve over time, document models allow multiple people to contribute, make changes, and track progress. They are central to Powerhouse's development approach, forming the backbone of adaptable workflows and versatile data management. Each document functions as a living entity, continuously evolving to reflect updates and interactions among contributors.",
        "updatedAt": "2026-05-13T13:00:32.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:32.000Z"
    }
  },
