    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Editors and UX",
        "createdAt": "2026-04-02T13:00:00.000Z",
        "description": "How editors connect React components to document state via hooks, dispatch operations, manage styling scope, and surface operational history to users.",
        "orientation": "Editors are where users actually interact with Powerhouse documents. They are React components that consume document state through generated hooks, dispatch operations through type-safe creators, and render domain-specific UIs for viewing and modifying content. But building effective editors requires understanding several interacting concerns: how the hook layer connects React to the document model runtime, how component architecture keeps editors modular and testable, how CSS scoping prevents style collisions when multiple editors coexist in Connect, and how the event-sourced operation history can be surfaced as a navigable revision timeline. This MOC threads together the full editor development story from state binding through styling to debugging tools."
      },
      "timestampUtcMs": "2026-05-13T13:00:50.000Z"
    }
  },
