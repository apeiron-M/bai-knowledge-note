    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Open-Source Capitalism is Powerhouse's economic philosophy. It acknowledges that open-source has dominated infrastructure but consistently struggled to capture value. The central promise is not just to build open alternatives, but to make them self-sustaining, investable, and scalable. Before redistributing value, OSS must first capture value. This means combining the pro-market, pro-innovation ethos of open-source with incentive structures that actually work -- so networks don't just survive, but thrive.",
        "updatedAt": "2026-05-13T13:00:38.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:38.000Z"
    }
  },
