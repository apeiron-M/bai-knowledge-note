    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Achra and Vetra share an identical light theme base palette defined under the :root selector. Surface colors: --background: #FCFCFC, --foreground: #343839, --foreground-70: rgba(52, 56, 57, 0.5), --foreground-50: rgba(52, 56, 57, 0.3). Card colors: --card: #FCFCFC, --card-foreground: #343839, --card-foreground-50: rgba(52, 56, 57, 0.5). Secondary: --secondary: #F4F4F4, --secondary-foreground: #343839. Muted: --muted: #EFEFEF, --muted-foreground: #9EA0A1. Border and input: --border: #D7D8D9, --input: #FFFFFF, --ring: #343839. Popover: --popover: #FFFFFF, --popover-foreground: #343839. Accent: --accent: #F3F5F7, --accent-foreground: #000000. The Powerhouse parent brand also shares these same light theme base values (with the exception of its unique gradient accent tokens). Source: colors.css files at https://github.com/powerhouse-inc/design-systems.",
        "updatedAt": "2026-05-13T13:00:36.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:36.000Z"
    }
  },
