    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Customization Layer consists of organization-specific plugins and instances of the host applications. It enables customization and deployment of unique platforms for each network organization. Examples include tailored Connect plugins for contributors, Switchboard plugins for aggregated data and APIs, Fusion plugins for custom marketplaces, and Renown/Academy plugins for reputation and training.",
        "updatedAt": "2026-05-13T13:00:31.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:31.000Z"
    }
