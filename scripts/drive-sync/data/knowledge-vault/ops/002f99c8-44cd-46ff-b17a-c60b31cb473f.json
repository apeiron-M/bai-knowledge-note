    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Multisig Participation Agreements (MPAs) are a foundational legal tool within the SNO framework. They define the roles and responsibilities of multisig wallet signers, ensuring accountability and mitigating internal liability risks. MPAs formalize governance processes, reduce chaos and inefficiency in decentralized decision-making, protect contributors by clarifying liability boundaries, and are fully customizable. They integrate seamlessly with Gnosis Safe wallets for transparent resource management.",
        "updatedAt": "2026-05-13T13:00:37.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:37.000Z"
    }
