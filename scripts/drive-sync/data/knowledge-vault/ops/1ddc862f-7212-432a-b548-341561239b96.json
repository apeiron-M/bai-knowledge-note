    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "DAOs promised a way forward for decentralized operations, but fell short: plagued by coordination failures, incentive misalignment, and lack of clarity around roles, responsibilities, and execution. Powerhouse emerged from this gap -- building systems that retain the openness of decentralized networks while introducing the operational rigor of traditional institutions. Transparency makes contributions, decisions, and payments legible, creating a persistent and auditable record of organizational behavior.",
        "updatedAt": "2026-05-13T13:00:40.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:40.000Z"
    }
  },
