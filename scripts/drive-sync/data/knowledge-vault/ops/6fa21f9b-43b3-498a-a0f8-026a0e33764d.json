    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Decentralized Operations Platform embeds accountability directly into its workflows. Actions taken on the platform generate verifiable records -- both financial and reputational -- that form a shared source of truth. Disputes can be resolved, work can be audited, and contributors can prove their track record across projects and teams. This persistent memory allows SNOs to grow while retaining coherence and trust. The platform supports modular service categories including governance operations, legal and financial services, and compliance.",
        "updatedAt": "2026-05-13T13:00:39.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:39.000Z"
    }
  },
