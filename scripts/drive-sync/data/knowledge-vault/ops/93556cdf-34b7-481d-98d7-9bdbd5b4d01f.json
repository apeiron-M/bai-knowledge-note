    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Deployment and Operations",
        "createdAt": "2026-04-02T13:00:00.000Z",
        "description": "Docker images, production service setup with nginx/PM2/SSL, environment configuration, document format migration, and the v6 reactor architecture transition.",
        "orientation": "Getting Powerhouse from development to production involves a layered deployment strategy. Docker images package Connect and Switchboard for containerized deployment, while the ph service setup command configures bare-metal installations with nginx reverse proxying, PM2 process management, and SSL termination. Environment variables override config.json for twelve-factor app compliance in cloud environments. Beyond initial deployment, the operations story includes document format migration \u2014 the PHDocument v4 header consolidation that streamlined the wire format \u2014 and the ongoing v6 reactor transition that replaces legacy REST endpoints with subgraph-based access, flattens operations to remove the strand abstraction, and provides custom subgraphs for ReactorClient consumers. This MOC captures both the how of getting Powerhouse running and the evolution of the runtime architecture itself."
      },
      "timestampUtcMs": "2026-05-13T13:00:50.000Z"
    }
  },
