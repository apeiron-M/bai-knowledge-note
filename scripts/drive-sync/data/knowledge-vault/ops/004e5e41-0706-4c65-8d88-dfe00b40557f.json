  {
    "index": 3,
    "hash": "6UkhpEqQ3Fz01VSmp3rE4h8fVF0=",
    "timestampUtcMs": "2026-05-13T13:00:26.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The `DocumentToolbar` accepts a `className` prop that is merged with the component's default Tailwind classes using `twMerge`. The defaults are:\n\n```\nflex h-12 w-full items-center justify-between rounded-xl border border-gray-200 bg-slate-50 px-4\n```\n\nTo override these defaults, you must use the `!` (important) prefix on your custom classes:\n\n```tsx\n<DocumentToolbar className=\"!bg-[#181825] !border-white/10\" />\n```\n\nWithout the `!` prefix, `twMerge` may resolve conflicts in favor of the defaults depending on specificity rules. The `!` prefix forces your values to take precedence.\n\nThis is a standard pattern when working with component libraries that use `twMerge` \u2014 the library controls base styling and consumers override specific properties via important modifiers.",
        "updatedAt": "2026-05-13T13:00:26.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:26.000Z"
    }
  },
