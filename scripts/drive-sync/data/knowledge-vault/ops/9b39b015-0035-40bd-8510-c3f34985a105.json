  {
    "index": 3,
    "hash": "Q+jY+LPWQ4vGlbnBsb2es+0RUwM=",
    "timestampUtcMs": "2026-05-13T13:00:48.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "When using Vetra Studio with `ph vetra --watch`, code generation is fully automatic:\n\n1. You create or modify specification documents in the Vetra Studio Drive browser UI\n2. Vetra monitors changes in real-time\n3. When a document model specification becomes valid, Vetra triggers code generation\n4. Terminal shows: `[Vetra] Document model TodoList is valid, proceeding with code generation`\n5. Validation errors are reported in the terminal to help identify missing specifications\n\nThis contrasts with the legacy Connect workflow where you must:\n1. Export a `.phd` file from Connect\n2. Manually run `ph generate TodoList.phd`\n\nIn **interactive mode** (`ph vetra --interactive`), Vetra prompts for confirmation before processing each change. In **standard mode**, changes are processed automatically with a 1-second debounce, batching multiple changes together.\n\nThe generated output is identical regardless of whether generation is automatic (Vetra) or manual (`ph generate`).",
        "updatedAt": "2026-05-13T13:00:48.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:48.000Z"
    }
  },
