  {
    "index": 3,
    "hash": "juuGqueNRPB1BVkF3NlNonoTgSo=",
    "timestampUtcMs": "2026-05-13T13:00:39.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Powerhouse packages follow a standard publishing workflow:\n\n1. **Package naming**: Scoped convention `@your-org-ph/your-package-name` (the `-ph` suffix identifies Powerhouse ecosystem packages)\n2. **manifest.json**: Declares package contents - document models (with document type IDs) and editors (linked to document types)\n3. **Build**: `pnpm build` or `npm run build` compiles to dist/\n4. **Publish**: `npm login` then `npm publish` (with `\"publishConfig\": { \"access\": \"public\" }` for scoped packages)\n5. **Install**: `ph install @your-org-ph/your-package-name` makes document models and editors available in any Powerhouse environment\n\nThe `package.json` `files` array should include: `dist`, `manifest.json`, `document-models`, `editors`.\n\nSemantic versioning is used for package versions. The AGPL-3.0-only license is common in the ecosystem.",
        "updatedAt": "2026-05-13T13:00:39.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:39.000Z"
    }
  },
