  {
    "index": 3,
    "hash": "zqlk7d4sRRrvTqRecnHNhNo4b4Q=",
    "timestampUtcMs": "2026-05-13T13:00:44.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "In any Powerhouse package, styles are generated through the `styles.css` file via `tailwindcss/cli`. Importing CSS directly in `.tsx` files works in development mode but will NOT be picked up in static production builds. All style imports must be centralized into `styles.css` using file import syntax (`@import \"...\"` not `@import url(\"...\")`, since `@import url()` is ignored by tailwindcss/cli). When installing a package with `ph install`, package styles are automatically added to styles.css.",
        "updatedAt": "2026-05-13T13:00:44.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:44.000Z"
    }
  },
