    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "TOPIC",
        "title": "ACT Encryption and Sharing",
        "createdAt": "2026-04-21T19:32:16.008Z",
        "description": "How Connect encrypts data at the Swarm /bytes layer with AES-256-GCM and uses ACT+ECDH for cross-user sharing without leaking the wallet key.",
        "orientation": "Connect's privacy story has two layers. At rest, every payload uploaded to /bytes is AES-256-GCM encrypted with a deterministic key derived from a one-time wallet signature so any device with the wallet can recover state. For sharing across users, Connect uses Swarm's ACT with ECDH-derived per-session keys and per-grantee manifests \u2014 replacing the older deriveShareKey approach that leaked through publicly derivable SHA-256. This MOC collects the notes that define the encryption layer, the ACT model, and the concrete flows (chat sharing, raw-file sharing, session keys) that depend on them."
      },
      "timestampUtcMs": "2026-05-13T13:00:50.000Z"
    }
  },
