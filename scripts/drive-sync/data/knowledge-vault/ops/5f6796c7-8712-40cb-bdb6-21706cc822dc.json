    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "TOPIC",
        "title": "Live Collaboration Track",
        "createdAt": "2026-04-21T19:32:25.350Z",
        "description": "Next-track design for live collaboration on Swarm: per-user op feeds, ACT-gated collab manifest, GSOC-triggered debounced pulls, no CRDT.",
        "orientation": "Live collaboration is the next major feature track after chat. This MOC consolidates the design notes: per-user operation feeds (not a shared feed, to avoid SOC write contention), ACT-gated collab manifests for participant discovery, and GSOC pings as the sub-second wake-up signal that triggers debounced pulls. The reactor's operation-based model handles concurrent edits natively, so no CRDT is needed. UX-wise the only surface is the document toolbar's History view \u2014 not per-editor presence \u2014 scoping the track tightly to what the primitives support."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
