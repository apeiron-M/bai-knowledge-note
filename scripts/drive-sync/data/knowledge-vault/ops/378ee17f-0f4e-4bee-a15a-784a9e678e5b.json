    "action": {
      "type": "CREATE_MOC",
      "input": {
        "tier": "DOMAIN",
        "title": "Vetra Tooling",
        "createdAt": "2026-04-02T13:00:00.000Z",
        "description": "The Vetra Studio development environment, specification-driven code generation, remote collaborative drives, package publishing, and the ph CLI.",
        "orientation": "Vetra Studio is the integrated development environment where Powerhouse document models go from concept to running code. It provides a visual builder for specification documents \u2014 the blueprints that define a document models schema, operations, and metadata. When a specification changes, Vetra automatically regenerates TypeScript code, keeping the gen/ folder in sync without manual intervention. Beyond individual development, Vetra supports collaborative workflows through remote drives that let multiple developers share and evolve specifications together. Once a document model is ready, the package system handles publishing to npm and installation via the ph CLI. This MOC traces the complete developer tooling story from initial specification authoring through code generation to package distribution, covering the module type system that organizes packages and the CLI commands that tie everything together."
      },
      "timestampUtcMs": "2026-05-13T13:00:49.000Z"
    }
  },
