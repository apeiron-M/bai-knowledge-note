  {
    "index": 3,
    "hash": "IhfsjS0BCv0pQ7VuAW0tEP271uk=",
    "timestampUtcMs": "2026-05-13T13:00:34.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Each document model gets a generated hook like `useSelectedTodoListDocument()` that returns `[document, dispatch]`. This is the recommended approach over the props-based `EditorProps<T>` pattern because it makes components self-contained, eliminates prop drilling, and follows modern React conventions. The props approach (`document` and `dispatch` passed from parent) is reserved for reusable UI components that should work outside the Powerhouse context or for testing with mock state. Action creators are imported from the generated document model package and passed to `dispatch()`.",
        "updatedAt": "2026-05-13T13:00:34.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:34.000Z"
    }
  },
