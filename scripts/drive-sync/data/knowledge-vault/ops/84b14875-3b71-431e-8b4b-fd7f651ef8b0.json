  {
    "index": 3,
    "hash": "fmGLB5PxoxqkebLKrmHESqGKa+s=",
    "timestampUtcMs": "2026-05-13T13:00:45.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Swarm exposes two storage primitives that Connect composes for sync:\n\n- `/bytes` \u2014 immutable, content-addressed. Upload data, get back a 64-char hex hash; the same data always yields the same hash and can never be mutated in place.\n- Feeds \u2014 mutable pointers identified by the pair `(topic, owner address)`. Only the owner can update what the feed points to, but anyone who knows the topic and owner can read it.\n\nConnect's write layering uses both: encrypted operation bytes are uploaded to `/bytes`, and the resulting reference is written to a feed. This lets readers look up a known topic (for example `ph:v2:doc:<documentId>`), follow the reference to `/bytes`, and fetch the latest encrypted batch.\n\nThe separation also clarifies where encryption belongs: encryption lives at the `/bytes` layer, while feeds hold plain-text references only.",
        "updatedAt": "2026-05-13T13:00:45.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:45.000Z"
    }
  },
