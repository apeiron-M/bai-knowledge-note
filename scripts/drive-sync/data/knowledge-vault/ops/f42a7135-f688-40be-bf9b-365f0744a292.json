  {
    "index": 3,
    "hash": "ngM6BVn7DGXpyFO0ls9HmaApQvo=",
    "timestampUtcMs": "2026-05-13T13:00:27.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "In the Analytics Engine, `AnalyticsDimension` objects have a `path` field using `/`-delimited hierarchical strings (like URIs). Querying with path `/atlas/mip40` matches all dimensions starting with that prefix. The LOD (level of detail) parameter controls result aggregation: LOD 0 groups all results into a single value; LOD 1 groups by the first path segment; LOD 2 by the first two segments, etc. LOD greater than the number of path parts appends `/*` wildcards but returns the same results as the highest meaningful level. Best practice: start with general queries (high LOD, broad path) and narrow down to specific paths and lower LODs for particular metrics. There will be thousands/millions of series objects but far fewer dimension objects.",
        "updatedAt": "2026-05-13T13:00:27.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:27.000Z"
    }
  },
