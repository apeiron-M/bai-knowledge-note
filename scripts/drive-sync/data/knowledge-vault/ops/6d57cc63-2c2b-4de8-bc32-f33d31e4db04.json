    "timestampUtcMs": "2026-05-13T13:00:48.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Vetra is the infrastructure and developer-facing layer of the Powerhouse ecosystem, focused on data sovereignty, portability, and open cloud. Its primary color is #04C161 (green), which remains constant across both light and dark themes. Vetra encompasses multiple developer-oriented products: Vetra Studio (a Connect instance for local development), Vetra Academy (learning resources), and Vetra Switchboard (a Switchboard instance for local dev). The vetra.io cloud platform is for publishing Reactor Packages and buying hosting. The Vetra design system package mirrors Achra's structure with color tokens, style guide, 16 website page templates, logos, document templates, presentations, and animation references. Source: https://github.com/powerhouse-inc/design-systems/tree/main/vetra.",
        "updatedAt": "2026-05-13T13:00:48.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:48.000Z"
    }
  },
