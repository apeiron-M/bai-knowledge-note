  {
    "index": 3,
    "hash": "HJm/bGgwOkhuosu0dsv8iFpI9dQ=",
    "timestampUtcMs": "2026-05-13T13:00:30.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "Custom scalars are created in `src/scalars/graphql/` of the document-engineering project. Each scalar file exports: `type` (TS type as string), `typedef` (GraphQL definition e.g. `'scalar PhoneNumber'`), `schema` (Zod validation), `stringSchema` (string representation for code generation), `config` (GraphQLScalarTypeConfig with name, description, serialize/parseValue/parseLiteral), and `scalar` (GraphQLScalarType instance). Registration in `scalars.ts` requires updating seven sections: namespace imports, type exports, export object, customScalars record, resolvers, typeDefs array, generatorTypeDefs, and validationSchema. Scalars can be integrated into React components by using `scalar.schema.safeParse(value)` for validation, enabling consistent frontend/backend validation.",
        "updatedAt": "2026-05-13T13:00:30.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:30.000Z"
    }
  },
