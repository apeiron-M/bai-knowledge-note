  {
    "index": 3,
    "hash": "rlLaDXvCuapoe1TR7PYwcceH1qs=",
    "timestampUtcMs": "2026-05-13T13:00:30.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "CQRS (Command Query Responsibility Segregation) is a key design principle in Powerhouse. Commands handle operations that modify state -- creating or updating documents -- validated and stored as events forming the immutable history. Queries are optimized for retrieval using read models designed for performance, scalability, and flexibility. This separation enables write and read models to scale independently, isolates business logic from query logic for maintainability, and supports multiple read model types (relational databases, full-text search, analytics).",
        "updatedAt": "2026-05-13T13:00:30.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:30.000Z"
    }
  },
