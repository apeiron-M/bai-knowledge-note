  {
    "index": 3,
    "hash": "+ihy+fdkmNTt+8uj9I3Pb0pALgo=",
    "timestampUtcMs": "2026-05-13T13:00:36.000Z",
    "action": {
      "type": "SET_CONTENT",
      "input": {
        "content": "The Powerhouse parent brand uses a distinctive illustrated card design pattern built with a three-layer CSS approach. The first layer is a dark surface background on the card element itself. The second layer is a radial gradient applied via a ::before pseudo-element, creating a subtle color wash or glow effect. The third layer is an illustration applied via an ::after pseudo-element, overlaying the gradient. This pattern creates depth and visual interest without requiring JavaScript or complex SVG composition. The complete implementation details and usage rules are documented in the card design guidelines file at https://github.com/powerhouse-inc/design-systems/blob/main/powerhouse/card-design-guidelines.html. This pattern is specific to the Powerhouse parent brand and is not used in the Achra or Vetra brand packages.",
        "updatedAt": "2026-05-13T13:00:36.000Z"
      },
      "timestampUtcMs": "2026-05-13T13:00:36.000Z"
    }
  },
